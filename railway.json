{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && npx tsc"
  },
  "deploy": {
    "startCommand": "cd backend && node dist/index.js",
    "healthcheckPath": "/api/health",
    "numReplicas": 1,
    "sleepApplication": true
  }
}